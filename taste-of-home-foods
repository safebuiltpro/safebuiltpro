}

html { scroll-behavior: smooth; }

body {
  font-family: 'Poppins', sans-serif;
  background: var(--bg);
  color: var(--text);
  overflow-x: hidden;
  font-weight: 300;
}

.serif { font-family: 'Cormorant Garamond', serif; }

img { display: block; max-width: 100%; }

a { text-decoration: none; color: inherit; }

button { font-family: inherit; cursor: pointer; border: none; background: none; }

.container {
  max-width: var(--container);
  margin: 0 auto;
  padding: 0 1.5rem;
}

/* ── NAV ── */
#navbar {
  position: fixed;
  top: 0;
  width: 100%;
  z-index: 100;
  transition: background 0.3s, padding 0.3s, box-shadow 0.3s;
  padding: 1.5rem 0;
}

#navbar.scrolled {
  background: rgba(246,240,228,0.97);
  backdrop-filter: blur(12px);
  box-shadow: 0 1px 12px rgba(0,0,0,0.06);
  padding: 1rem 0;
}

.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

#navbar .logo { height: 48px; width: auto; object-fit: contain; }

.nav-links {
  display: flex;
  align-items: center;
  gap: 2rem;
  list-style: none;
  font-size: 0.875rem;
  font-weight: 500;
}

.nav-links button {
  color: var(--text);
  transition: color 0.2s;
  font-size: 0.875rem;
  font-weight: 500;
}

.nav-links button:hover { color: var(--secondary); }

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 0.65rem 1.5rem;
  border-radius: 999px;
  font-family: 'Poppins', sans-serif;
  font-weight: 500;
  font-size: 0.9rem;
  cursor: pointer;
  transition: background 0.2s, color 0.2s, transform 0.2s, box-shadow 0.2s;
  border: none;
}

.btn-primary { background: var(--primary); color: #fff; }
.btn-primary:hover { background: var(--primary-light); }

.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 2px solid var(--primary);
}
.btn-outline:hover { background: var(--primary); color: #fff; }

.btn-gold { background: var(--secondary); color: #fff; }
.btn-gold:hover { background: var(--secondary-dark); }

.btn-lg { padding: 0.85rem 2rem; font-size: 1rem; }

.hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  width: 26px;
  cursor: pointer;
}
.hamburger span {
  display: block;
  height: 2px;
  background: var(--primary);
  border-radius: 2px;
  transition: all 0.3s;
}
.hamburger.open span:nth-child(1) { transform: rotate(45deg) translate(5px,5px); }
.hamburger.open span:nth-child(2) { opacity: 0; }
.hamburger.open span:nth-child(3) { transform: rotate(-45deg) translate(5px,-5px); }

#mobile-menu {
  display: none;
  flex-direction: column;
  gap: 0;
  background: var(--bg);
  border-top: 1px solid var(--border);
  padding: 0.5rem 1.5rem 1.5rem;
}

#mobile-menu.open { display: flex; }

#mobile-menu button {
  padding: 0.8rem 0;
  border-bottom: 1px solid var(--border);
  text-align: left;
  font-size: 0.95rem;
  font-weight: 500;
  color: var(--text);
}

#mobile-menu .btn { margin-top: 1rem; border-radius: 999px; }

/* ── HERO ── */
#hero {
  padding: 10rem 0 6rem;
  position: relative;
  overflow: hidden;
  min-height: 100vh;
  display: flex;
  align-items: center;
}

.hero-orb-1 {
  position: absolute;
  top: -200px;
  right: -200px;
  width: 700px;
  height: 700px;
  background: rgba(212,160,23,0.12);
  border-radius: 50%;
  filter: blur(60px);
  pointer-events: none;
}

.hero-orb-2 {
  position: absolute;
  bottom: -200px;
  left: -200px;
  width: 500px;
  height: 500px;
  background: rgba(26,60,37,0.06);
  border-radius: 50%;
  filter: blur(60px);
  pointer-events: none;
}

.hero-content {
  max-width: 780px;
  margin: 0 auto;
  text-align: center;
  position: relative;
  z-index: 1;
}

.hero-label {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--secondary);
  margin-bottom: 1.5rem;
  display: block;
  opacity: 0;
  transform: translateY(20px);
  animation: fadeUp 0.7s ease forwards 0.1s;
}

.hero-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(3rem, 8vw, 6rem);
  font-weight: 500;
  line-height: 1.08;
  color: var(--primary);
  margin-bottom: 1.5rem;
  opacity: 0;
  transform: translateY(20px);
  animation: fadeUp 0.7s ease forwards 0.25s;
}

.hero-title em {
  font-style: italic;
  color: var(--secondary);
}

.hero-sub {
  font-size: clamp(1rem, 2vw, 1.15rem);
  color: var(--text-muted);
  font-weight: 300;
  line-height: 1.7;
  max-width: 600px;
  margin: 0 auto 2.5rem;
  opacity: 0;
  transform: translateY(20px);
  animation: fadeUp 0.7s ease forwards 0.4s;
}

.hero-ctas {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  justify-content: center;
  opacity: 0;
  transform: translateY(20px);
  animation: fadeUp 0.7s ease forwards 0.55s;
}

@keyframes fadeUp {
  to { opacity: 1; transform: translateY(0); }
}

/* ── TRUST BADGES ── */
#trust {
  padding: 3.5rem 0;
  background: var(--card);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}

.trust-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2rem;
}

.trust-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 0.75rem;
}

.trust-icon {
  width: 52px;
  height: 52px;
  border-radius: 50%;
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  color: var(--primary);
}

.trust-icon svg { width: 24px; height: 24px; stroke: var(--primary); fill: none; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }

.trust-item h3 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--primary);
}

.trust-item p { font-size: 0.76rem; color: var(--text-muted); }

/* ── STORY ── */
#story { padding: 6rem 0; overflow: hidden; }

.story-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}

.story-text h2 {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(2rem, 4vw, 3.2rem);
  font-weight: 500;
  color: var(--primary);
  line-height: 1.25;
  margin-bottom: 1.5rem;
}

.story-text h2 em { font-style: italic; color: var(--secondary); }

.story-text p {
  color: var(--text-muted);
  font-weight: 300;
  font-size: 1.05rem;
  line-height: 1.8;
  margin-bottom: 1.25rem;
}

.story-quote {
  border-left: 3px solid var(--secondary);
  padding: 0.5rem 0 0.5rem 1.25rem;
  font-weight: 500;
  color: var(--primary);
  font-size: 1rem;
}

.story-img-wrap {
  position: relative;
}

.story-img-frame {
  aspect-ratio: 4/5;
  border-radius: 999px 999px 2rem 2rem;
  overflow: hidden;
  border: 8px solid var(--card);
  box-shadow: 0 20px 60px rgba(0,0,0,0.15);
  position: relative;
  z-index: 1;
}

.story-img-frame img { width: 100%; height: 100%; object-fit: cover; }

.story-glow {
  position: absolute;
  top: 50%;
  right: -2rem;
  width: 130px;
  height: 130px;
  background: var(--secondary);
  border-radius: 50%;
  filter: blur(50px);
  opacity: 0.45;
}

/* ── PRODUCTS ── */
#products { padding: 6rem 0; background: var(--card); }

.section-label {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--secondary);
  margin-bottom: 1rem;
  display: block;
  text-align: center;
}

.section-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 500;
  color: var(--primary);
  text-align: center;
  margin-bottom: 4rem;
}

.products-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
}

.product-card {
  background: var(--bg);
  border-radius: var(--radius);
  overflow: hidden;
  border: 1px solid var(--border);
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  transition: box-shadow 0.3s, transform 0.3s;
}

.product-card:hover {
  box-shadow: 0 12px 40px rgba(0,0,0,0.13);
  transform: translateY(-4px);
}

.product-img {
  aspect-ratio: 1/1;
  overflow: hidden;
  position: relative;
  background: var(--card);
}

.product-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
}

.product-card:hover .product-img img { transform: scale(1.06); }

.product-img-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.08);
  transition: background 0.3s;
}

.product-card:hover .product-img-overlay { background: transparent; }

.product-body { padding: 1.75rem 2rem; }

.product-body h3 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 0.6rem;
}

.product-body p {
  font-size: 0.82rem;
  color: var(--text-muted);
  line-height: 1.65;
  margin-bottom: 1.5rem;
  min-height: 55px;
}

.product-card .btn {
  width: 100%;
  transition: background 0.3s, color 0.3s;
}

/* ── SHIPPING ── */
#shipping { padding: 6rem 0; }

.shipping-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}

.shipping-text h2 {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(2rem, 3.5vw, 3rem);
  font-weight: 500;
  color: var(--primary);
  margin-bottom: 1rem;
}

.shipping-text p {
  color: var(--text-muted);
  font-weight: 300;
  line-height: 1.8;
  margin-bottom: 2rem;
}

.country-list { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; }

.country-list li {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  font-weight: 500;
  color: var(--primary);
  font-size: 1rem;
}

.country-list li::before {
  content: '';
  display: block;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--secondary);
  flex-shrink: 0;
}

.shipping-flags {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

.flag-card {
  background: var(--card);
  border-radius: var(--radius);
  padding: 2rem 1rem;
  text-align: center;
  border: 1px solid var(--border);
}

.flag-emoji { font-size: 2.5rem; margin-bottom: 0.5rem; line-height: 1; }

.flag-card h4 {
  font-family: 'Cormorant Garamond', serif;
  font-weight: 700;
  font-size: 1.1rem;
  color: var(--primary);
}

/* ── TESTIMONIALS ── */
#testimonials { padding: 6rem 0; }

.testimonials-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
  max-width: 960px;
  margin: 0 auto;
  align-items: center;
}

.testimonial-card {
  background: var(--card);
  border-radius: var(--radius);
  padding: 2.25rem;
  position: relative;
}

.testimonial-card.featured {
  background: var(--primary);
  color: #fff;
  transform: translateY(-1rem);
  box-shadow: 0 20px 50px rgba(26,60,37,0.3);
}

.quote-mark {
  font-family: 'Cormorant Garamond', serif;
  font-size: 4rem;
  line-height: 1;
  color: var(--secondary);
  opacity: 0.4;
  position: absolute;
  top: 1rem;
  left: 1.5rem;
}

.testimonial-card p {
  font-style: italic;
  color: var(--text-muted);
  line-height: 1.7;
  margin-top: 1.25rem;
  margin-bottom: 1.5rem;
  font-size: 0.95rem;
  position: relative;
  z-index: 1;
}

.testimonial-card.featured p { color: rgba(255,255,255,0.88); }

.testimonial-author {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  border-top: 1px solid var(--border);
  padding-top: 1rem;
}

.testimonial-card.featured .testimonial-author { border-color: rgba(255,255,255,0.15); }

.author-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: rgba(26,60,37,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Cormorant Garamond', serif;
  font-weight: 700;
  font-size: 1.1rem;
  color: var(--primary);
  flex-shrink: 0;
}

.testimonial-card.featured .author-avatar {
  background: rgba(255,255,255,0.12);
  color: #fff;
}

.author-name {
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--primary);
}

.testimonial-card.featured .author-name { color: #fff; }

.author-location { font-size: 0.75rem; color: var(--text-muted); }

.testimonial-card.featured .author-location { color: rgba(255,255,255,0.6); }

/* ── CTA SECTION ── */
#cta {
  padding: 6rem 0;
  background: var(--primary);
  color: #fff;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.cta-glow {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at center, rgba(212,160,23,0.15) 0%, transparent 70%);
  pointer-events: none;
}

#cta h2 {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(2rem, 5vw, 4rem);
  font-weight: 500;
  margin-bottom: 1.25rem;
  position: relative;
  z-index: 1;
}

#cta p {
  font-size: 1.05rem;
  color: rgba(255,255,255,0.75);
  font-weight: 300;
  margin-bottom: 2.5rem;
  position: relative;
  z-index: 1;
}

/* ── FAQ ── */
#faq { padding: 6rem 0; background: var(--bg); }

.faq-list { max-width: 720px; margin: 0 auto; display: flex; flex-direction: column; gap: 1rem; }

details {
  background: var(--card);
  border-radius: var(--radius);
  overflow: hidden;
}

summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.4rem 1.75rem;
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--primary);
  cursor: pointer;
  list-style: none;
  gap: 1rem;
}

summary::-webkit-details-marker { display: none; }

summary .chevron {
  width: 20px;
  height: 20px;
  flex-shrink: 0;
  stroke: var(--secondary);
  fill: none;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
  transition: transform 0.3s ease;
}

details[open] summary .chevron { transform: rotate(180deg); }

.faq-answer {
  padding: 0 1.75rem 1.5rem;
  color: var(--text-muted);
  font-weight: 300;
  font-size: 0.95rem;
  line-height: 1.8;
}

/* ── FOOTER ── */
footer {
  background: var(--card);
  border-top: 1px solid var(--border);
  padding: 4rem 0 2rem;
}

.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  gap: 3rem;
  margin-bottom: 3rem;
}

.footer-brand img { height: 56px; width: auto; object-fit: contain; margin-bottom: 1rem; }

.footer-brand p {
  color: var(--text-muted);
  font-size: 0.9rem;
  line-height: 1.7;
  max-width: 280px;
}

.footer-col h4 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 1.25rem;
}

.footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; }

.footer-col ul li a,
.footer-col ul li button {
  font-size: 0.88rem;
  color: var(--text-muted);
  transition: color 0.2s;
}

.footer-col ul li a:hover,
.footer-col ul li button:hover { color: var(--secondary); }

.footer-col ul li .whatsapp-link { color: var(--secondary); font-weight: 500; }

.footer-bottom {
  border-top: 1px solid var(--border);
  padding-top: 2rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 1rem;
  font-size: 0.82rem;
  color: var(--text-muted);
}

/* ── FLOATING WHATSAPP ── */
#whatsapp-float {
  position: fixed;
  bottom: 1.5rem;
  right: 1.5rem;
  z-index: 200;
  background: var(--whatsapp);
  color: #fff;
  width: 58px;
  height: 58px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6px 24px rgba(0,0,0,0.2);
  cursor: pointer;
  transition: background 0.2s, transform 0.2s;
  animation: popIn 0.5s cubic-bezier(0.34,1.56,0.64,1) 1s both;
  border: none;
}

#whatsapp-float:hover {
  background: var(--whatsapp-dark);
  transform: scale(1.1);
}

#whatsapp-float svg { width: 28px; height: 28px; fill: #fff; }

.wa-tooltip {
  position: absolute;
  right: calc(100% + 1rem);
  top: 50%;
  transform: translateY(-50%);
  background: var(--bg);
  color: var(--text);
  font-size: 0.82rem;
  font-weight: 500;
  padding: 0.5rem 1rem;
  border-radius: 8px;
  white-space: nowrap;
  box-shadow: 0 4px 16px rgba(0,0,0,0.1);
  border: 1px solid var(--border);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s;
}

#whatsapp-float:hover .wa-tooltip { opacity: 1; }

@keyframes popIn {
  from { opacity: 0; transform: scale(0); }
  to { opacity: 1; transform: scale(1); }
}

/* ── SCROLL REVEAL ── */
.reveal {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.65s ease, transform 0.65s ease;
}

.reveal.visible { opacity: 1; transform: translateY(0); }

.reveal-left {
  opacity: 0;
  transform: translateX(-40px);
  transition: opacity 0.8s ease, transform 0.8s ease;
}

.reveal-left.visible { opacity: 1; transform: translateX(0); }

.reveal-right {
  opacity: 0;
  transform: translateX(40px);
  transition: opacity 0.8s ease, transform 0.8s ease;
}

.reveal-right.visible { opacity: 1; transform: translateX(0); }

.stagger-1 { transition-delay: 0.05s; }
.stagger-2 { transition-delay: 0.15s; }
.stagger-3 { transition-delay: 0.25s; }
.stagger-4 { transition-delay: 0.35s; }
.stagger-5 { transition-delay: 0.45s; }
.stagger-6 { transition-delay: 0.55s; }
.stagger-7 { transition-delay: 0.65s; }

/* ── RESPONSIVE ── */
@media (max-width: 1024px) {
  .products-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 768px) {
  .nav-links { display: none; }
  .hamburger { display: flex; }

  .trust-grid { grid-template-columns: repeat(2, 1fr); }

  .story-grid,
  .shipping-grid { grid-template-columns: 1fr; }

  .story-img-wrap { max-width: 340px; margin: 0 auto; }

  .products-grid { grid-template-columns: 1fr; }

  .testimonials-grid { grid-template-columns: 1fr; }
  .testimonial-card.featured { transform: none; }

  .footer-grid { grid-template-columns: 1fr; }

  .footer-bottom { flex-direction: column; text-align: center; }
}

@media (max-width: 480px) {
  .trust-grid { grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
  .hero-ctas { flex-direction: column; align-items: center; }
  .hero-ctas .btn { width: 100%; max-width: 300px; }
  .shipping-flags { grid-template-columns: repeat(3, 1fr); gap: 0.75rem; }
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --primary: #1A3C25;
  --primary-light: #2a5c3a;
  --secondary: #D4A017;
  --secondary-dark: #b8890f;
  --bg: #F6F0E4;
